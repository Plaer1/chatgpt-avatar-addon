{
  "manifest_version": 3,
  "name": "ChatGPT Avatars",
  "version": "2.1.0",
  "description": "Lightweight inline avatars for ChatGPT with local avatar cropping.",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "ico/icon16.png",
    "32": "ico/icon32.png",
    "48": "ico/icon48.png",
    "128": "ico/icon128.png"
  }
}
