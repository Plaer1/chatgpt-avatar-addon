{
  "manifest_version": 3,
  "name": "ChatGPT Avatars",
  "version": "2.1.0",
  "description": "Lightweight inline avatars for ChatGPT with local avatar cropping.",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
